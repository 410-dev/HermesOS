# DO NOT EDIT THIS FILE!
# This datapack contains HERMES partition table.

cd "$(dirname "$0")/../../"
export ROOTFS="$PWD"

# Read-Only
export SYSTEM="$ROOTFS/System"
export SYSLIB="$SYSTEM/lib"
export BOOTSECT="$SYSTEM/boot"
export RECOVERY="$SYSTEM/lib/recovery"
export CORE="$ROOTFS/System/core"

# Read and Write
export DATA="$ROOTFS/Data"
export LIBRARY="$DATA/Library"
export USERDATA="$DATA/Users"

# Temporary
export CACHE="$ROOTFS/cache"
export BOOTREFUSE="$CACHE/xboot"
